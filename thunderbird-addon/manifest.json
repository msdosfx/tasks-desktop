{
  "manifest_version": 3,
  "name": "Tasks Desktop",
  "version": "0.1.0",
  "description": "Tasks.org-compatible task manager with CalDAV sync, running inside Thunderbird.",
  "author": "Arlis",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tasks-desktop@arlis",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background/index.js"],
    "type": "module"
  },
  "action": {
    "default_title": "Tasks Desktop",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "permissions": ["storage", "alarms"],
  "optional_host_permissions": ["*://*/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+T"
      },
      "description": "Open Tasks Desktop"
    }
  }
}
